generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── RBAC ─────────────────────────────────────────────────────────────────────

model Role {
  id          Int            @id @default(autoincrement())
  code        String         @unique
  nameAr      String
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime       @default(now())
}

model Permission {
  id      Int            @id @default(autoincrement())
  code    String         @unique
  group   String
  nameAr  String
  roles   RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ── USERS ─────────────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  roleId       Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  branchId     Int?

  role             Role             @relation(fields: [roleId], references: [id])
  branch            Branch?          @relation("BranchUsers", fields: [branchId], references: [id])
  stockMovements   StockMovement[]
  managedWarehouses Warehouse[]
  salesInvoices    SalesInvoice[]
  workOrders       WorkOrder[]
  stockCountsCreated      StockCount[]
  vouchersCreated         Voucher[]
  journalEntriesCreated   JournalEntry[]
  promissoryNotesCreated  PromissoryNote[]
  fixedAssetsCreated      FixedAsset[]
  payrollRunsCreated      PayrollRun[]
  recurringEntriesCreated RecurringEntry[]
  approvalsCreated        JournalEntryApproval[] @relation("ApprovalMaker")
  approvalsReviewed       JournalEntryApproval[] @relation("ApprovalChecker")
}

// ── BRANCHES ──────────────────────────────────────────────────────────────────

model Branch {
  id            Int       @id @default(autoincrement())
  nameAr        String
  code          String?   // رمز الفرع — يُستخدم في تقرير مزامنة الفروع
  address       String?
  phone         String?
  isActive      Boolean   @default(true)
  lastSyncedAt  DateTime? // آخر مرة تم فيها تحديث/التحقق من بيانات الفرع يدويًا

  warehouses Warehouse[] @relation("BranchWarehouses")
  users      User[]      @relation("BranchUsers")
}

// ── DEPARTMENTS ───────────────────────────────────────────────────────────────

model Department {
  id            Int          @id @default(autoincrement())
  nameAr        String
  descriptionAr String?
  parentId      Int?
  icon          String?
  parent        Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children      Department[] @relation("DepartmentTree")
  products      Product[]
}

// ── BRANDS ────────────────────────────────────────────────────────────────────

model Brand {
  id        Int       @id @default(autoincrement())
  nameAr    String
  logoUrl   String?
  sortOrder Int       @default(0)
  products  Product[]
}

// ── UNITS ─────────────────────────────────────────────────────────────────────

model Unit {
  id       Int       @id @default(autoincrement())
  nameAr   String
  code     String    @unique
  products Product[]
}

// ── PRODUCTS ──────────────────────────────────────────────────────────────────

model Product {
  id           Int            @id @default(autoincrement())
  nameAr       String
  sku          String         @unique
  barcode      String?
  departmentId Int?
  brandId      Int?
  unitId       Int?
  costPrice    Decimal        @db.Decimal(12, 2)
  salePrice    Decimal        @db.Decimal(12, 2)
  wholesalePrice     Decimal? @db.Decimal(12, 2)
  halfWholesalePrice Decimal? @db.Decimal(12, 2)
  taxRate      Decimal        @db.Decimal(5, 2)  @default(0)
  expiryDate   DateTime?      // تاريخ انتهاء الصلاحية — حقل واحد لكل منتج (وليس دفعات)
  reorderPoint Decimal?       @db.Decimal(12, 2) // حد إعادة الطلب — إذا كان الرصيد أقل منه أو يساويه يُقترح الطلب
  reorderQty   Decimal?       @db.Decimal(12, 2) // الكمية المقترحة لإعادة الطلب (اختياري، وإلا تُحسب تلقائياً)
  imageUrl     String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())

  department     Department?      @relation(fields: [departmentId], references: [id])
  brand          Brand?           @relation(fields: [brandId], references: [id])
  unit           Unit?            @relation(fields: [unitId], references: [id])
  stockBalances  StockBalance[]
  stockMovements StockMovement[]
  invoiceItems   SalesInvoiceItem[]
  purchaseItems  PurchaseInvoiceItem[]
  transferItems  StockTransferItem[]
  stockCountLines StockCountLine[]
  bom                  BillOfMaterial? @relation("BOMFinishedProduct")
  bomLinesAsComponent  BOMLine[]       @relation("BOMLineComponent")
  workOrders           WorkOrder[]     @relation("WorkOrderFinishedProduct")
  workOrderLinesAsComponent WorkOrderLine[] @relation("WorkOrderLineComponent")
}

// ── WAREHOUSES ────────────────────────────────────────────────────────────────

model Warehouse {
  id         Int            @id @default(autoincrement())
  nameAr     String
  location   String?
  managerId  Int?
  branchId   Int?
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())

  manager        User?            @relation(fields: [managerId], references: [id])
  branch         Branch?          @relation("BranchWarehouses", fields: [branchId], references: [id])
  stockBalances  StockBalance[]
  stockMovements StockMovement[]
  salesInvoices  SalesInvoice[]
  purchaseInvoices PurchaseInvoice[]
  transfersFrom  StockTransfer[]  @relation("TransferFrom")
  transfersTo    StockTransfer[]  @relation("TransferTo")
  stockCounts    StockCount[]
  workOrders     WorkOrder[]
}

// ── STOCK ─────────────────────────────────────────────────────────────────────

model StockBalance {
  id          Int       @id @default(autoincrement())
  productId   Int
  warehouseId Int
  quantity    Decimal   @db.Decimal(12, 2) @default(0)

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

enum MovementType {
  IN
  OUT
  TRANSFER
  ADJUST
}

model StockMovement {
  id           Int          @id @default(autoincrement())
  productId    Int
  warehouseId  Int
  type         MovementType
  quantity     Decimal      @db.Decimal(12, 2)
  balanceAfter Decimal      @db.Decimal(12, 2)
  refType      String?
  refId        Int?
  reason       String?
  createdById  Int?
  createdAt    DateTime     @default(now())

  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  createdBy   User?     @relation(fields: [createdById], references: [id])

  @@index([productId, warehouseId])
  @@index([refType, refId])
  @@index([createdAt])
}

// ── STOCK COUNT (الجرد المخزني) ─────────────────────────────────────────────────

enum StockCountStatus {
  DRAFT
  POSTED
}

model StockCount {
  id          Int              @id @default(autoincrement())
  countNo     String           @unique
  warehouseId Int
  date        DateTime         @default(now())
  status      StockCountStatus @default(DRAFT)
  notes       String?
  createdById Int?
  postedAt    DateTime?
  createdAt   DateTime         @default(now())

  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  createdBy User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  lines     StockCountLine[]

  @@index([warehouseId])
  @@index([status])
}

model StockCountLine {
  id           Int     @id @default(autoincrement())
  stockCountId Int
  productId    Int
  systemQty    Decimal @db.Decimal(12, 2)
  countedQty   Decimal @db.Decimal(12, 2)

  stockCount StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@unique([stockCountId, productId])
}

// ── MANUFACTURING (أوامر التصنيع وقوائم المكونات) ────────────────────────────────

model BillOfMaterial {
  id        Int       @id @default(autoincrement())
  productId Int       @unique // المنتج النهائي — قائمة مكونات واحدة نشطة لكل منتج
  notes     String?
  createdAt DateTime  @default(now())

  product    Product     @relation("BOMFinishedProduct", fields: [productId], references: [id])
  lines      BOMLine[]
  workOrders WorkOrder[]
}

model BOMLine {
  id          Int     @id @default(autoincrement())
  bomId       Int
  componentId Int
  qtyPerUnit  Decimal @db.Decimal(12, 4) // كمية المكون اللازمة لإنتاج وحدة واحدة من المنتج النهائي

  bom       BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  component Product        @relation("BOMLineComponent", fields: [componentId], references: [id])

  @@unique([bomId, componentId])
}

enum WorkOrderStatus {
  DRAFT
  POSTED
  CANCELLED
}

model WorkOrder {
  id          Int             @id @default(autoincrement())
  orderNo     String          @unique
  bomId       Int
  productId   Int             // المنتج النهائي — نُسخة من bom.productId وقت الإنشاء
  warehouseId Int
  qty         Decimal         @db.Decimal(12, 2) // الكمية المطلوب تصنيعها
  status      WorkOrderStatus @default(DRAFT)
  date        DateTime        @default(now())
  notes       String?
  createdById Int?
  postedAt    DateTime?
  createdAt   DateTime        @default(now())

  bom       BillOfMaterial   @relation(fields: [bomId], references: [id])
  product   Product          @relation("WorkOrderFinishedProduct", fields: [productId], references: [id])
  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  createdBy User?            @relation(fields: [createdById], references: [id])
  lines     WorkOrderLine[]

  @@index([status])
  @@index([warehouseId])
}

model WorkOrderLine {
  id          Int     @id @default(autoincrement())
  workOrderId Int
  componentId Int
  qtyPerUnit  Decimal @db.Decimal(12, 4) // نسخة من BOMLine وقت إنشاء الأمر
  qtyRequired Decimal @db.Decimal(12, 2) // qtyPerUnit × كمية أمر التصنيع

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  component Product   @relation("WorkOrderLineComponent", fields: [componentId], references: [id])
}

// ── CUSTOMERS ─────────────────────────────────────────────────────────────────

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

model Customer {
  id             Int            @id @default(autoincrement())
  nameAr         String
  company        String?
  phone          String?
  vatNumber      String?        // الرقم الضريبي للعميل — للفواتير الضريبية القياسية (B2B)
  creditLimit    Decimal        @db.Decimal(12, 2) @default(0)
  openingBalance Decimal        @db.Decimal(12, 2) @default(0)
  currentBalance Decimal        @db.Decimal(12, 2) @default(0)
  loyaltyPoints  Decimal        @db.Decimal(12, 2) @default(0) // رصيد نقاط الولاء الحالي
  status         CustomerStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())

  invoices            SalesInvoice[]
  loyaltyTransactions LoyaltyTransaction[]
}

// ── SALES INVOICES ────────────────────────────────────────────────────────────

enum PaidStatus {
  PAID
  UNPAID
  PARTIAL
}

enum PaymentMethod {
  CASH
  CARD
  CREDIT
}

enum ZatcaStatus {
  NOT_CONFIGURED // لم تُضبط بيانات الفوترة الإلكترونية (شهادة الاعتماد) بعد
  PENDING        // جاهزة للإرسال ولم تُرسل بعد
  REPORTED       // تم إرسالها والإبلاغ عنها (فاتورة مبسّطة B2C)
  CLEARED        // تمت المصادقة عليها من هيئة الزكاة والضريبة والجمارك (فاتورة ضريبية B2B)
  FAILED         // فشل الإرسال — راجع zatcaResponse لتفاصيل الخطأ
}

model SalesInvoice {
  id             Int           @id @default(autoincrement())
  refNo          String        @unique
  customerId     Int
  warehouseId    Int
  cashierId      Int
  date           DateTime      @default(now())
  subtotal       Decimal       @db.Decimal(12, 2)
  discount       Decimal       @db.Decimal(12, 2) @default(0)
  tax            Decimal       @db.Decimal(12, 2) @default(0)
  total          Decimal       @db.Decimal(12, 2)
  paidStatus     PaidStatus    @default(UNPAID)
  paymentMethod  PaymentMethod @default(CASH)
  couponId       Int?          // الكوبون المستخدم في هذه الفاتورة (إن وجد)
  pointsEarned   Decimal       @db.Decimal(12, 2) @default(0) // نقاط الولاء المكتسبة من هذه الفاتورة
  pointsRedeemed Decimal       @db.Decimal(12, 2) @default(0) // نقاط الولاء المستبدلة كخصم في هذه الفاتورة
  createdAt      DateTime      @default(now())

  // ── ZATCA Phase 2 (الفوترة الإلكترونية — ربط ومصادقة) ──────────────────────
  invoiceHash         String?      // تجزئة (SHA-256) لمحتوى هذه الفاتورة — لسلسلة الربط
  previousInvoiceHash String?      // تجزئة الفاتورة السابقة في السلسلة (PIH)
  zatcaStatus         ZatcaStatus  @default(NOT_CONFIGURED)
  zatcaUuid           String?      // المُعرّف الفريد المُرسَل إلى هيئة الزكاة
  zatcaSubmittedAt    DateTime?
  zatcaResponse       String?      // آخر استجابة/رسالة خطأ من هيئة الزكاة — للتشخيص

  customer            Customer             @relation(fields: [customerId], references: [id])
  warehouse           Warehouse            @relation(fields: [warehouseId], references: [id])
  cashier             User                 @relation(fields: [cashierId], references: [id])
  coupon              Coupon?              @relation(fields: [couponId], references: [id])
  items               SalesInvoiceItem[]
  vouchers            Voucher[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([customerId])
  @@index([warehouseId])
  @@index([date])
}

// ── LOYALTY POINTS & DISCOUNT COUPONS (نقاط الولاء وكوبونات الخصم) ────────────────

enum CouponType {
  PERCENTAGE
  FIXED
}

model Coupon {
  id                Int        @id @default(autoincrement())
  code              String     @unique
  type              CouponType
  value             Decimal    @db.Decimal(12, 2) // نسبة % أو مبلغ ثابت حسب النوع
  minPurchaseAmount Decimal    @db.Decimal(12, 2) @default(0)
  maxDiscountAmount Decimal?   @db.Decimal(12, 2) // سقف الخصم — يُستخدم فقط مع النوع "نسبة"
  validFrom         DateTime?
  validTo           DateTime?
  usageLimit        Int?       // الحد الأقصى لعدد مرات الاستخدام الإجمالي — null = بلا حد
  usedCount         Int        @default(0)
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())

  invoices SalesInvoice[]
}

enum LoyaltyTxType {
  EARN
  REDEEM
  ADJUST
}

model LoyaltyTransaction {
  id             Int           @id @default(autoincrement())
  customerId     Int
  type           LoyaltyTxType
  points         Decimal       @db.Decimal(12, 2)
  salesInvoiceId Int?
  description    String?
  createdAt      DateTime      @default(now())

  customer     Customer      @relation(fields: [customerId], references: [id])
  salesInvoice SalesInvoice? @relation(fields: [salesInvoiceId], references: [id])
}

model SalesInvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int
  productId Int
  qty       Decimal @db.Decimal(12, 2)
  unitPrice Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(12, 2)

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

// ── SUPPLIERS ─────────────────────────────────────────────────────────────────

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

model Supplier {
  id             Int            @id @default(autoincrement())
  nameAr         String
  company        String?
  phone          String?
  openingBalance Decimal        @db.Decimal(12, 2) @default(0)
  currentBalance Decimal        @db.Decimal(12, 2) @default(0)
  status         SupplierStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())

  purchaseInvoices PurchaseInvoice[]
}

// ── PURCHASE INVOICES ─────────────────────────────────────────────────────────

enum ReceiveStatus {
  RECEIVED
  PENDING
}

model PurchaseInvoice {
  id            Int           @id @default(autoincrement())
  refNo         String        @unique
  supplierId    Int
  warehouseId   Int
  date          DateTime      @default(now())
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @db.Decimal(12, 2) @default(0)
  tax           Decimal       @db.Decimal(12, 2) @default(0)
  total         Decimal       @db.Decimal(12, 2)
  paymentStatus PaidStatus    @default(UNPAID)
  receiveStatus ReceiveStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())

  supplier  Supplier             @relation(fields: [supplierId], references: [id])
  warehouse Warehouse            @relation(fields: [warehouseId], references: [id])
  items     PurchaseInvoiceItem[]
  vouchers  Voucher[]

  @@index([supplierId])
  @@index([warehouseId])
  @@index([date])
}

model PurchaseInvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int
  productId Int
  qty       Decimal @db.Decimal(12, 2)
  unitCost  Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(12, 2)

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

// ── ACCOUNTS ──────────────────────────────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model Account {
  id             Int         @id @default(autoincrement())
  code           String      @unique
  nameAr         String
  type           AccountType
  parentId       Int?
  openingBalance Decimal     @db.Decimal(12, 2) @default(0)
  currentBalance Decimal     @db.Decimal(12, 2) @default(0)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())

  parent       Account?       @relation("AccountTree", fields: [parentId], references: [id])
  children     Account[]      @relation("AccountTree")
  expenses     Expense[]
  journalLines JournalLine[]
  voucherTreasury Voucher[]   @relation("VoucherTreasuryAccount")
  voucherLines VoucherLine[]
  budgets      Budget[]
  recurringEntryLines RecurringEntryLine[]
  approvalLines JournalEntryApprovalLine[]

  @@index([type])
  @@index([parentId])
}

// ── JOURNAL ───────────────────────────────────────────────────────────────────

enum JournalSource {
  SALES_INVOICE
  PURCHASE_INVOICE
  EXPENSE
  MANUAL
  OPENING
  VOUCHER
  DEPRECIATION
  PAYROLL
  YEAR_CLOSE
  RECURRING
}

model JournalEntry {
  id          Int           @id @default(autoincrement())
  entryNo     String        @unique
  date        DateTime
  description String
  sourceType  JournalSource
  sourceId    Int?
  totalDebit  Decimal       @db.Decimal(12, 2)
  totalCredit Decimal       @db.Decimal(12, 2)
  createdById Int?
  createdAt   DateTime      @default(now())

  lines JournalLine[]
  voucher Voucher?
  approvalRequest JournalEntryApproval?
  payrollRun PayrollRun?
  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([sourceType, sourceId])
  @@index([date])
}

model JournalLine {
  id          Int     @id @default(autoincrement())
  entryId     Int
  accountId   Int
  costCenterId Int?
  debit       Decimal @db.Decimal(12, 2) @default(0)
  credit      Decimal @db.Decimal(12, 2) @default(0)
  description String?

  entry      JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account    Account      @relation(fields: [accountId], references: [id])
  costCenter CostCenter?  @relation(fields: [costCenterId], references: [id])

  @@index([accountId])
  @@index([entryId])
  @@index([costCenterId])
}

// ── COST CENTERS (مراكز التكلفة) ──────────────────────────────────────────────

model CostCenter {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  nameAr    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  journalLines JournalLine[]
  budgets      Budget[]
  recurringEntryLines RecurringEntryLine[]
  approvalLines JournalEntryApprovalLine[]
}

// ── BUDGETS (الموازنات التقديرية) ──────────────────────────────────────────────

model Budget {
  id           Int      @id @default(autoincrement())
  accountId    Int
  costCenterId Int?
  year         Int
  month        Int      // 1-12
  amount       Decimal  @db.Decimal(12, 2) @default(0)
  createdAt    DateTime @default(now())

  account    Account     @relation(fields: [accountId], references: [id])
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id])

  @@unique([accountId, costCenterId, year, month])
  @@index([year, month])
}

// ── RECURRING JOURNAL ENTRIES (القيود المتكررة) ────────────────────────────────

model RecurringEntry {
  id          Int       @id @default(autoincrement())
  description String
  dayOfMonth  Int       @default(1) // 1-28, day of month to post on
  startDate   DateTime  @default(now())
  endDate     DateTime?
  lastRunDate DateTime?
  isActive    Boolean   @default(true)
  createdById Int?
  createdAt   DateTime  @default(now())

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)
  lines RecurringEntryLine[]
}

model RecurringEntryLine {
  id               Int     @id @default(autoincrement())
  recurringEntryId Int
  accountId        Int
  costCenterId     Int?
  debit            Decimal @db.Decimal(12, 2) @default(0)
  credit           Decimal @db.Decimal(12, 2) @default(0)
  description      String?

  recurringEntry RecurringEntry @relation(fields: [recurringEntryId], references: [id], onDelete: Cascade)
  account        Account        @relation(fields: [accountId], references: [id])
  costCenter     CostCenter?    @relation(fields: [costCenterId], references: [id])

  @@index([recurringEntryId])
  @@index([accountId])
}

// ── JOURNAL ENTRY APPROVALS (سير الاعتماد — Maker-Checker) ─────────────────────
// Manual journal entries are staged here first; the account balances are only
// touched once a *different* user (never the maker) approves the request.

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model JournalEntryApproval {
  id             Int            @id @default(autoincrement())
  description    String
  date           DateTime
  status         ApprovalStatus @default(PENDING)
  createdById    Int
  reviewedById   Int?
  reviewedAt     DateTime?
  rejectReason   String?
  journalEntryId Int?           @unique
  createdAt      DateTime       @default(now())

  lines        JournalEntryApprovalLine[]
  journalEntry JournalEntry?              @relation(fields: [journalEntryId], references: [id])
  createdBy    User                       @relation("ApprovalMaker", fields: [createdById], references: [id])
  reviewedBy   User?                      @relation("ApprovalChecker", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
}

model JournalEntryApprovalLine {
  id           Int     @id @default(autoincrement())
  requestId    Int
  accountId    Int
  costCenterId Int?
  debit        Decimal @db.Decimal(12, 2) @default(0)
  credit       Decimal @db.Decimal(12, 2) @default(0)
  description  String?

  request    JournalEntryApproval @relation(fields: [requestId], references: [id], onDelete: Cascade)
  account    Account              @relation(fields: [accountId], references: [id])
  costCenter CostCenter?          @relation(fields: [costCenterId], references: [id])

  @@index([requestId])
  @@index([accountId])
}

// ── PARTNERS ──────────────────────────────────────────────────────────────────

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

model Partner {
  id              Int           @id @default(autoincrement())
  nameAr          String
  email           String?
  phone           String?
  capitalRequired Decimal       @db.Decimal(12, 2) @default(0)
  capitalPaid     Decimal       @db.Decimal(12, 2) @default(0)
  profitSharePct  Decimal       @db.Decimal(5, 2)  @default(0)
  currentBalance  Decimal       @db.Decimal(12, 2) @default(0)
  status          PartnerStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
}

// ── STOCK TRANSFERS ───────────────────────────────────────────────────────────

enum TransferStatus {
  DONE
  PENDING
}

model StockTransfer {
  id                Int            @id @default(autoincrement())
  transferNo        String         @unique
  fromWarehouseId   Int
  toWarehouseId     Int
  date              DateTime       @default(now())
  status            TransferStatus @default(PENDING)
  notes             String?
  createdAt         DateTime       @default(now())

  fromWarehouse Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  items         StockTransferItem[]

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

model StockTransferItem {
  id         Int     @id @default(autoincrement())
  transferId Int
  productId  Int
  qty        Decimal @db.Decimal(12, 2)

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id])

  @@index([transferId])
  @@index([productId])
}

// ── SETTINGS ─────────────────────────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── AUDIT LOG ─────────────────────────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  userName   String?
  method     String
  path       String
  action     String?
  entity     String?
  statusCode Int
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// ── EXPENSES ──────────────────────────────────────────────────────────────────

model Expense {
  id          Int      @id @default(autoincrement())
  accountId   Int?
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())

  account Account? @relation(fields: [accountId], references: [id])

  @@index([date])
  @@index([accountId])
}

// ── VOUCHERS / TREASURY ───────────────────────────────────────────────────────

enum VoucherType {
  RECEIPT
  PAYMENT
  DISCOUNT
  DEPOSIT
}

enum PartyType {
  CUSTOMER
  SUPPLIER
  ACCOUNT
}

model Voucher {
  id                Int         @id @default(autoincrement())
  voucherNo         String      @unique
  type              VoucherType
  date              DateTime    @default(now())
  treasuryAccountId Int
  partyType         PartyType?
  partyId           Int?
  salesInvoiceId    Int?
  purchaseInvoiceId Int?
  description       String?
  totalAmount       Decimal     @db.Decimal(12, 2) @default(0)
  journalEntryId    Int?        @unique
  createdById       Int?
  createdAt         DateTime    @default(now())

  treasuryAccount Account          @relation("VoucherTreasuryAccount", fields: [treasuryAccountId], references: [id])
  journalEntry    JournalEntry?    @relation(fields: [journalEntryId], references: [id])
  salesInvoice    SalesInvoice?    @relation(fields: [salesInvoiceId], references: [id])
  purchaseInvoice PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id])
  createdBy       User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  lines           VoucherLine[]
  settledNotes    PromissoryNote[]

  @@index([type])
  @@index([date])
  @@index([treasuryAccountId])
  @@index([partyType, partyId])
  @@index([salesInvoiceId])
  @@index([purchaseInvoiceId])
}

model VoucherLine {
  id          Int            @id @default(autoincrement())
  voucherId   Int
  accountId   Int
  amount      Decimal        @db.Decimal(12, 2) @default(0)
  description String?

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  @@index([voucherId])
  @@index([accountId])
}

// ── PROMISSORY NOTES (الكمبيالات) ─────────────────────────────────────────────

enum NoteType {
  RECEIVABLE
  PAYABLE
}

enum NoteStatus {
  PENDING
  SETTLED
  CANCELLED
  BOUNCED
}

enum NoteInstrumentType {
  PROMISSORY_NOTE
  CHEQUE
}

model PromissoryNote {
  id                Int       @id @default(autoincrement())
  noteNo            String    @unique
  type              NoteType
  instrumentType    NoteInstrumentType @default(PROMISSORY_NOTE)
  bankName          String?   // اسم البنك — للشيكات فقط
  partyType         PartyType
  partyId           Int?
  amount            Decimal   @db.Decimal(12, 2) @default(0)
  issueDate         DateTime  @default(now())
  dueDate           DateTime
  status            NoteStatus @default(PENDING)
  description       String?
  settledVoucherId  Int?
  createdById       Int?
  createdAt         DateTime  @default(now())

  settledVoucher Voucher? @relation(fields: [settledVoucherId], references: [id])
  createdBy      User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([dueDate])
  @@index([partyType, partyId])
}

// ── FIXED ASSETS (الأصول الثابتة) ─────────────────────────────────────────────

enum AssetCategory {
  EQUIPMENT
  VEHICLE
  FURNITURE
  BUILDING
  OTHER
}

enum DepreciationMethod {
  STRAIGHT_LINE
}

enum AssetStatus {
  ACTIVE
  DISPOSED
}

model FixedAsset {
  id                       Int                 @id @default(autoincrement())
  assetCode                String              @unique
  nameAr                   String
  category                 AssetCategory       @default(OTHER)
  purchaseDate             DateTime            @default(now())
  purchaseCost             Decimal             @db.Decimal(12, 2)
  salvageValue             Decimal             @db.Decimal(12, 2) @default(0)
  usefulLifeMonths         Int
  depreciationMethod       DepreciationMethod  @default(STRAIGHT_LINE)
  accumulatedDepreciation  Decimal             @db.Decimal(12, 2) @default(0)
  bookValue                Decimal             @db.Decimal(12, 2) @default(0)
  status                   AssetStatus         @default(ACTIVE)
  description              String?
  createdById              Int?
  createdAt                DateTime            @default(now())

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([status])
}

// ── HUMAN RESOURCES / PAYROLL (الموارد البشرية والرواتب) ──────────────────────

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum PayrollStatus {
  DRAFT
  POSTED
}

model Employee {
  id           Int             @id @default(autoincrement())
  nameAr       String
  nationalId   String?
  phone        String?
  position     String?
  department   String?
  managerId    Int?            // المسؤول المباشر — يُستخدم لبناء الهيكل التنظيمي
  basicSalary  Decimal         @db.Decimal(12, 2) @default(0)
  allowances   Decimal         @db.Decimal(12, 2) @default(0)
  deductions   Decimal         @db.Decimal(12, 2) @default(0)
  bankAccount  String?
  hireDate     DateTime        @default(now())
  status       EmployeeStatus  @default(ACTIVE)
  createdAt    DateTime        @default(now())

  manager       Employee?     @relation("EmployeeManager", fields: [managerId], references: [id])
  directReports Employee[]    @relation("EmployeeManager")
  payrollItems  PayrollItem[]

  @@index([status])
}

model PayrollRun {
  id          Int           @id @default(autoincrement())
  runNo       String        @unique
  month       Int
  year        Int
  totalGross  Decimal       @db.Decimal(12, 2) @default(0)
  totalDeductions Decimal    @db.Decimal(12, 2) @default(0)
  totalNet    Decimal       @db.Decimal(12, 2) @default(0)
  status      PayrollStatus @default(DRAFT)
  journalEntryId Int?       @unique
  createdById Int?
  createdAt   DateTime      @default(now())

  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])
  createdBy    User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  items PayrollItem[]

  @@index([month, year])
}

model PayrollItem {
  id           Int       @id @default(autoincrement())
  payrollRunId Int
  employeeId   Int
  basic        Decimal   @db.Decimal(12, 2) @default(0)
  allowances   Decimal   @db.Decimal(12, 2) @default(0)
  deductions   Decimal   @db.Decimal(12, 2) @default(0)
  net          Decimal   @db.Decimal(12, 2) @default(0)

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@index([payrollRunId])
  @@index([employeeId])
}
